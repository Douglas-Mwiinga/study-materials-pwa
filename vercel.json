{
  "outputDirectory": "frontend",
  "functions": {
    "api/[...route].js": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!api(?:/|$)|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
